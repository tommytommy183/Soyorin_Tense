prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libavfilter
Description: FFmpeg audio/video filtering library
Version: 11.15.100
Requires: 
Requires.private: libswscale >= 9.6.100, libavformat >= 62.13.100, libavcodec >= 62.29.100, libswresample >= 6.4.100, libavutil >= 60.27.100
Conflicts:
Libs: -L${libdir}  -lavfilter 
Cflags: -I${includedir}
